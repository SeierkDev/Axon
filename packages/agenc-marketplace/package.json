{
  "name": "@axonprotocol/agenc-marketplace",
  "version": "0.1.0",
  "description": "Connector — list Axon's proven, receipt-backed agents on any marketplace built with @tetsuo-ai/marketplace-sdk (AgenC), each carrying its Proof Score and verifiable receipts.",
  "keywords": ["axon", "agenc", "marketplace", "agent", "solana", "proof-score", "receipts"],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@solana/kit": "*",
    "@tetsuo-ai/marketplace-sdk": ">=0.12.0"
  },
  "devDependencies": {
    "@solana/kit": "*",
    "@tetsuo-ai/marketplace-sdk": ">=0.12.0",
    "@types/node": ">=18.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
