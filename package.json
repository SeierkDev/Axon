{
  "name": "axon",
  "version": "0.1.0",
  "private": true,
  "author": "Seierk",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "axon": "tsx src/cli/axon.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint",
    "check:local": "tsx --env-file=.env.local scripts/prelaunch-check.ts --local",
    "check:production": "tsx --env-file=.env.local scripts/prelaunch-check.ts --production",
    "cleanup:demo": "tsx --env-file=.env.local scripts/cleanup-demo-data.ts",
    "contract:api-errors": "tsx --env-file=.env.local scripts/api-error-contract.ts",
    "contract:auth-task": "tsx --env-file=.env.local scripts/auth-task-contract.ts",
    "contract:health": "tsx --env-file=.env.local scripts/health-contract.ts",
    "contract:payments": "tsx --env-file=.env.local scripts/payment-contract.ts",
    "contract:bidding": "tsx --env-file=.env.local scripts/bidding-contract.ts",
    "contract:splits": "tsx --env-file=.env.local scripts/splits-contract.ts",
    "contract:workflow-templates": "tsx --env-file=.env.local scripts/workflow-templates-contract.ts",
    "contract:attestations": "tsx --env-file=.env.local scripts/attestations-contract.ts",
    "contract:sla": "tsx --env-file=.env.local scripts/sla-contract.ts",
    "contract:abuse": "tsx --env-file=.env.local scripts/abuse-contract.ts",
    "contract:governance": "tsx --env-file=.env.local scripts/governance-contract.ts",
    "contract:worker-shutdown": "tsx --env-file=.env.local scripts/worker-shutdown-contract.ts",
    "contract:webhook-health": "tsx --env-file=.env.local scripts/webhook-health-contract.ts",
    "demo:agent": "tsx --env-file=.env.local scripts/demo-agent.ts",
    "demo:bids": "tsx --env-file=.env.local scripts/demo-bids.ts",
    "backup:db": "tsx --env-file=.env.local scripts/backup-db.ts",
    "restore:db": "tsx --env-file=.env.local scripts/restore-db.ts",
    "migrate:db": "tsx --env-file=.env.local scripts/migrate-db.ts",
    "prelaunch": "npm run check:production",
    "smoke:first-task": "tsx --env-file=.env.local scripts/smoke-first-task.ts",
    "smoke:devnet-payment": "SOLANA_NETWORK=devnet tsx --env-file=.env.local scripts/smoke-payment-devnet.ts",
    "verify:local": "tsx --env-file=.env.local scripts/verify-local.ts",
    "presence": "tsx src/server/presence.ts",
    "worker": "AXON_WORKER_STANDALONE=1 tsx src/workers/index.ts",
    "worker:local": "AXON_WORKER_STANDALONE=1 tsx --env-file=.env.local src/workers/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@libsql/client": "^0.17.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.10.0",
    "@solana/program-client-core": "^6.10.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@tetsuo-ai/marketplace-sdk": "^0.11.0",
    "better-sqlite3": "^12.10.0",
    "framer-motion": "^12.40.0",
    "next": "16.2.7",
    "postprocessing": "^6.39.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.185.0",
    "tsx": "^4.22.4",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "litesvm": "^1.2.1",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
