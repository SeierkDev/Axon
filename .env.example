# Axon production env template

# ── Database ──────────────────────────────────────────────────────────────────
#
# Option A — SQLite on a mounted volume (simplest, Railway/Fly.io):
#   DATABASE_PATH=/data/axon.db      ← absolute path on a persistent volume
#
# Option B — Turso (hosted libsql, recommended for production):
#   DATABASE_URL=libsql://your-db-name.turso.io
#   DATABASE_AUTH_TOKEN=your-token-from-turso-dashboard
#   DATABASE_PATH=/data/axon-replica.db   ← local embedded replica path
#
# On startup, Axon syncs the Turso remote into DATABASE_PATH and opens it
# via better-sqlite3. Writes are pushed back to Turso in the background.
# Get started: https://turso.tech — create a DB, copy the URL + auth token.
#
# Option C — PostgreSQL (planned, not yet supported):
#   DATABASE_URL=postgresql://user:pass@host/axon

DATABASE_PATH=/data/axon.db
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# Solana payments
SOLANA_NETWORK=mainnet-beta
HELIUS_API_KEY=your_helius_api_key
NEXT_PUBLIC_PAYMENT_RECEIVER_WALLET_ADDRESS=your_payment_receiver_wallet

# Optional. Only needed if Axon should sign on-chain refunds for funded MPP channels.
# Must be a JSON array of 64 bytes whose public key matches NEXT_PUBLIC_PAYMENT_RECEIVER_WALLET_ADDRESS.
REFUND_SIGNER_PRIVATE_KEY=

# Hosted inference agents
ANTHROPIC_API_KEY=your_anthropic_api_key
# Required only for agents registered with provider: "openai".
OPENAI_API_KEY=your_openai_api_key

# Protected daily seed endpoint
# Generate a long random value; do not use the local placeholder.
SEED_SECRET=replace_with_a_long_random_secret

# Trust proxy IP headers only when your deployment platform sets them correctly.
TRUST_PROXY_HEADERS=true

# Structured JSON logs. Use debug, info, warn, or error.
LOG_LEVEL=info

# Leave unset in real production. Set true only for temporary local/CI smoke tests
# that intentionally run production-mode Next.js against throwaway SQLite.
AXON_ALLOW_EPHEMERAL_DB=false

# Cron endpoint security
# Set a long random secret and pass it as: Authorization: Bearer <CRON_SECRET>
# Railway cron setup:
#   POST /api/cron/webhooks  — every 1 min  (flushes pending webhook deliveries with exponential-backoff retries)
#   POST /api/cron/health    — every 5 min  (pings agent endpoints, updates verification_status)
# Leave unset in dev to allow unauthenticated calls.
CRON_SECRET=replace_with_a_long_random_secret

# Moderation security — gates the abuse-report queue and resolution endpoints
# (GET /api/abuse-reports, POST /api/abuse-reports/<id>/resolve).
# Pass as: Authorization: Bearer <MODERATION_SECRET>. Leave unset in dev to allow.
MODERATION_SECRET=replace_with_a_long_random_secret

# Telegram bot integration (optional)
# Create a bot via @BotFather, add it to your channel as admin, and get the channel ID.
# Railway cron: POST /api/cron/telegram-feed every 2 hours with CRON_SECRET auth.
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# CORS — controls Access-Control-Allow-Origin on all /api/* responses.
# Leave unset (or set to *) for a public developer API.
# Set to your frontend origin (e.g. https://app.example.com) to restrict in production.
# CORS_ORIGIN=*

# AgenC cross-listing target. "sandbox" (default) verifies listings against
# AgenC's compiled program in-process (dev machines with litesvm installed;
# production without it records listings as "prepared" — same derived ids).
# Switch to "devnet"/"mainnet" once AgenC's Phase-2 redeploy lands.
# AGENC_CLUSTER=sandbox

# Local/demo helpers
AXON_DEMO_ENDPOINT=http://localhost:3000
AXON_SMOKE_ENDPOINT=http://localhost:3000
